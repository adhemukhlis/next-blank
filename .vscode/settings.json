{
	"application.experimental.rendererProfiling": false,
	"editor.accessibilitySupport": "off",
	"editor.aiStats.enabled": false,
	"editor.allowVariableFontsInAccessibilityMode": false,
	"editor.autoIndent": "full",
	"editor.codeActionsOnSave": { "source.fixAll.eslint": "always", "source.sort.json": "always" },
	"editor.codeActionWidget.includeNearbyQuickFixes": false,
	"editor.codeActionWidget.showHeaders": false,
	"editor.codeLens": false,
	"editor.cursorSmoothCaretAnimation": "on",
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.dragAndDrop": false,
	"editor.dropIntoEditor.enabled": false,
	"editor.experimentalGpuAcceleration": "off",
	"editor.fontLigatures": true,
	"editor.formatOnSave": false,
	"editor.hover.delay": 1000,
	"editor.hover.enabled": "on",
	"editor.links": false,
	"editor.minimap.side": "left",
	"editor.renderFinalNewline": "on",
	"editor.renderLineHighlightOnlyWhenFocus": true,
	"editor.smoothScrolling": true,
	"files.autoSave": "onFocusChange",
	"files.exclude": { "*.tsbuildinfo": true, "**/.git/**": true, "**/.next/**": true, "**/node_modules/**": true },
	"files.watcherExclude": { "*.tsbuildinfo": true, "**/.git/**": true, "**/.next/**": true, "**/node_modules/**": true },
	"git.autorefresh": false,
	"gitlens.telemetry.enabled": false,
	"scm.alwaysShowActions": false,
	"scm.alwaysShowRepositories": false,
	"search.exclude": { "*.tsbuildinfo": true, "**/.next/**": true, "**/node_modules/**": true, "**/pnpm-lock.yaml": true, "next-env.d.ts": true },
	"search.searchOnTypeDebouncePeriod": 600,
	"telemetry.editStats.details.enabled": false,
	"telemetry.editStats.enabled": false,
	"telemetry.editStats.showDecorations": false,
	"telemetry.editStats.showStatusBar": false,
	"telemetry.feedback.enabled": false
}
