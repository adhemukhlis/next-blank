				"useFragmentSyntax": "off",
				"useGlobalThis": "off",
				"useGraphqlNamingConvention": "off",
				"useGroupedAccessorPairs": "off",
				"useImportType": "warn",
				"useInputName": "off",
				"useLiteralEnumMembers": "off",
				"useLoneExecutableDefinition": "off",
				"useNamingConvention": "off",
				"useNodeAssertStrict": "off",
				"useNodejsImportProtocol": "off",
				"useNumberNamespace": "off",
				"useNumericSeparators": "off",
				"useObjectSpread": "off",
				"useReactFunctionComponents": "off",
				"useReadonlyClassProperties": "off",
				"useSelfClosingElements": "warn",
				"useShorthandAssign": "warn",
				"useShorthandFunctionType": "off",
				"useSingleVarDeclarator": "off",
				"useSpreadOverApply": "off",
				"useSymbolDescription": "off",
				"useTemplate": "warn",
				"useThrowNewError": "off",
				"useThrowOnlyError": "off",
				"useTrimStartEnd": "off",
				"useUnifiedTypeSignatures": "off",
