				"useValidTypeof": "off",
				"useVueValidTemplateRoot": "off",
				"useVueValidVBind": "off",
				"useVueValidVCloak": "off",
				"useVueValidVElse": "off",
				"useVueValidVElseIf": "off",
				"useVueValidVHtml": "off",
				"useVueValidVIf": "off",
				"useVueValidVOn": "off",
				"useVueValidVOnce": "off",
				"useVueValidVPre": "off",
				"useVueValidVText": "off",
				"useVueVForKey": "off",
				"useYield": "off"
			},
			"performance": {
				"noAccumulatingSpread": "off",
				"noAwaitInLoops": "off",
				"noBarrelFile": "off",
				"noDelete": "off",
				"noDynamicNamespaceImportAccess": "off",
				"noImgElement": "off",
