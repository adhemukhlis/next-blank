				"noBlankTarget": "off",
				"noDangerouslySetInnerHtml": "warn",
				"noDangerouslySetInnerHtmlWithChildren": "off",
				"noGlobalEval": "error",
				"noScriptUrl": "off",
				"noSecrets": "off"
