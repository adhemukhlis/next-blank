				"noUselessLoneBlockStatements": "off",
				"noUselessRename": "warn",
				"noUselessReturn": "off",
				"noUselessStringConcat": "off",
				"noUselessStringRaw": "off",
				"noUselessSwitchCase": "off",
				"noUselessTernary": "off",
				"noUselessThisAlias": "off",
				"noUselessTypeConstraint": "off",
				"noUselessUndefined": "off",
				"noUselessUndefinedInitialization": "off",
				"noVoid": "off",
				"useArrayFind": "off",
				"useArrowFunction": "off",
				"useDateNow": "off",
				"useFlatMap": "off",
				"useIndexOf": "off",
				"useLiteralKeys": "off",
				"useMaxParams": "off",
				"useNumericLiterals": "off",
				"useOptionalChain": "warn",
				"useRegexLiterals": "off",
				"useSimpleNumberKeys": "off",
				"useSimplifiedLogicExpression": "off",
				"useWhile": "off"
			},
			"correctness": {
