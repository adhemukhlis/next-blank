				"noChildrenProp": "off",
				"noConstantCondition": "off",
				"noConstantMathMinMaxClamp": "off",
				"noConstAssign": "off",
				"noConstructorReturn": "off",
				"noDuplicateArgumentNames": "off",
				"noDuplicateAttributes": "off",
				"noDuplicateEnumValueNames": "off",
				"noDuplicateInputFieldNames": "off",
				"noDuplicateVariableNames": "off",
				"noEmptyCharacterClassInRegex": "off",
				"noEmptyPattern": "off",
				"noGlobalDirnameFilename": "off",
				"noGlobalObjectCalls": "off",
				"noInnerDeclarations": "off",
				"noInvalidBuiltinInstantiation": "off",
				"noInvalidConstructorSuper": "off",
