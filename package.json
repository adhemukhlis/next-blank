{
	"name": "next-blank",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "node server.js dev",
		"start": "node server.js start",
		"build": "next build",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"fix": "eslint --fix .",
		"format": "prettier --config .prettierrc --log-level silent --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,css,scss,less,json,yml,yaml,md}\"",
		"minify": "prettier --config .minifyrc --log-level silent --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,css,scss,less,json,yml,yaml,md}\"",
		"deps:upgrade": "pnpm up --latest",
		"deps:reset": "rm -rf node_modules .next pnpm-lock.yaml && pnpm store prune && pnpm install",
		"unused": "pnpx knip --no-exit-code 2>&1 | tail -n +2 > knip-report.txt"
	},
	"dependencies": {
		"next": "^16.2.9",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@cspell/eslint-plugin": "^10.0.1",
		"@eslint-react/eslint-plugin": "^5.10.0",
		"@eslint/js": "^10.0.1",
		"@next/eslint-plugin-next": "^16.2.9",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "^26.0.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.6.0",
		"eslint-plugin-perfectionist": "^5.9.1",
		"globals": "^17.7.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"browserslist": [
		"chrome 111",
		"edge 111",
		"firefox 111",
		"safari 16.4"
	]
}
