{
	"browserslist": [
		"> 0.5% in ID",
		"not dead",
		"not op_mini all",
		"baseline widely available"
	],
	"dependencies": {
		"next": "^16.2.10",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"typescript": "^7.0.2"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"name": "next-blank",
	"packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
	"private": true,
	"scripts": {
		"build": "next build",
		"deps:reset": "rm -rf node_modules .next pnpm-lock.yaml && pnpm store prune && pnpm install",
		"deps:show": "pnpm list --depth=Infinity",
		"deps:upgrade": "pnpm up --latest",
		"dev": "node server.js dev",
		"fix": "biome check --fix .",
		"format": "biome format --write .",
		"lint": "biome check .",
		"size": "du -k -d 1 . | sort -nr > size.txt",
		"start": "node server.js start",
		"typecheck": "tsc --noEmit",
		"unused": "pnpx knip --no-exit-code 2>&1 | tail -n +2 > knip-report.txt"
	},
	"version": "0.1.0"
}