{
	"name": "nextmax",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "node server.js dev",
		"start": "node server.js start",
		"build": "next build",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"fix": "eslint --fix .",
		"format": "prettier --config .prettierrc --log-level silent --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,css,scss,less,json,yml,yaml,md}\"",
		"deps:upgrade": "pnpm up --latest",
		"deps:reset": "rm -rf node_modules .next pnpm-lock.yaml && pnpm store prune && pnpm install"
	},
	"dependencies": {
		"next": "^16.2.4",
		"react": "^19.2.5",
		"react-dom": "^19.2.5"
	},
	"devDependencies": {
		"@eslint-react/eslint-plugin": "^4.2.3",
		"@eslint/js": "^10.0.1",
		"@next/eslint-plugin-next": "^16.2.4",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.2.0",
		"eslint-plugin-import-x": "^4.16.2",
		"globals": "^17.5.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.2"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"browserslist": [
		"chrome 111",
		"edge 111",
		"firefox 111",
		"safari 16.4"
	]
}
