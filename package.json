{
	"name": "next-blank",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "node server.js dev",
		"start": "node server.js start",
		"build": "next build",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"fix": "eslint --fix .",
		"format": "prettier --config .prettierrc --log-level silent --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,css,scss,less,json,yml,yaml,md}\"",
		"minify": "prettier --config .minifyrc --log-level silent --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,css,scss,less,json,yml,yaml,md}\"",
		"deps:upgrade": "pnpm up --latest",
		"deps:reset": "rm -rf node_modules .next pnpm-lock.yaml && pnpm store prune && pnpm install",
		"unused": "pnpx knip --no-exit-code 2>&1 | tail -n +2 > knip-report.txt"
	},
	"dependencies": {
		"next": "^16.2.10",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@cspell/dict-id-id": "^1.0.7",
		"@cspell/eslint-plugin": "^10.0.1",
		"@eslint-react/eslint-plugin": "^5.11.3",
		"@eslint/js": "^10.0.1",
		"@next/eslint-plugin-next": "^16.2.10",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "^26.1.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.6.0",
		"eslint-plugin-perfectionist": "^5.10.0",
		"globals": "^17.7.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
	"browserslist": [
		"> 0.5% in ID",
		"not dead",
		"not op_mini all",
		"baseline widely available"
	]
}
